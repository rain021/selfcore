{
  "manifest_version": 3,
  "name": "SelfCore — AI Context Bridge",
  "version": "1.0.0",
  "description": "Inject your personal AI identity context into any AI chat.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1:8100/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://chat.mistral.ai/*",
        "https://x.com/*",
        "https://grok.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SelfCore"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
